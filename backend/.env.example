# Backend Environment Variables
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=scamshield_lao
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated fallback chain — if a model is rate-limited upstream, the next one is tried
DEEPSEEK_MODEL=openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-31b-it:free,nousresearch/hermes-3-llama-3.1-405b:free
ALLOWED_ORIGINS=chrome-extension://,http://localhost:3000,http://localhost:3001
PORT=8000
